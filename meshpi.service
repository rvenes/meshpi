[Unit]
Description=MeshPi Meshtastic CLI-teneste
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=meshpi
Group=meshpi
WorkingDirectory=/opt/meshpi
EnvironmentFile=/etc/meshpi.env
Environment=PYTHONDONTWRITEBYTECODE=1
ExecStart=/opt/meshpi/.venv/bin/meshpi daemon
Restart=on-failure
RestartSec=5
StateDirectory=meshpi
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/lib/meshpi

[Install]
WantedBy=multi-user.target
